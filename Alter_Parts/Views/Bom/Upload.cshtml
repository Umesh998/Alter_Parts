        .rm-panel {
            padding: 20px 15px;
        }

        .rm-btn {
            padding: 12px 20px;
            font-size: 0.9rem;
            letter-spacing: 1px;
        }
    }

    /* ── RESPONSIVE: MOBILE ── */
    @@media (max-width: 576px) {
        .rm-container {
            padding: 0 12px;
        }

        .rm-header {
            font-size: 1.2rem;
            letter-spacing: 1px;
        }

        .rm-subtitle {
            font-size: 0.75rem;
            letter-spacing: 0.5px;
        }

        .rm-panel {
            padding: 16px 12px;
        }

        .rm-info-block {
            padding: 14px 12px;
        }

        .rm-info-list li {
            font-size: 0.8rem;
        }

        .rm-tag {
            font-size: 0.72rem;
            padding: 2px 6px;
        }

        .rm-tag-desc {
            font-size: 0.78rem;
            width: 100%; /* Force description to new line on small screens */
        }

        .rm-file-input {
            font-size: 0.8rem;
            padding: 10px 10px;
        }

            .rm-file-input::file-selector-button {
                padding: 5px 8px;
                font-size: 0.75rem;
                margin-right: 8px;
            }

        .rm-btn {
            font-size: 0.82rem;
            padding: 12px 16px;
            letter-spacing: 0.5px;
        }
    }
</style>

<div class="rm-theme-wrapper">
    <div class="rm-container">

        <h2 class="rm-header">BOM <span>Upload Matrix</span></h2>
        <div class="rm-subtitle">
            SYSTEM INSTRUCTION: Upload target file. Matrix will only process rows flagged as
            <span class="rm-highlight">alternate</span> or <span class="rm-highlight">suggested</span>.
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="rm-alert-danger">
                [!] SYSTEM EXCEPTION: @ViewBag.Error
            </div>
        }

        <div class="rm-panel">
            <form asp-action="Upload" method="post" enctype="multipart/form-data">

                <div style="margin-bottom: 25px;">
                    <label class="rm-input-label">Select Target File (.xlsx / .xls)</label>
                    <input type="file" name="bomFile" class="rm-file-input" accept=".xlsx,.xls" required />
                </div>

                <div class="rm-info-block">
                    <div class="rm-info-header">Required Matrix Parameters</div>
                    <ul class="rm-info-list">
                        <li>
                            <span class="rm-icon-success">■</span>
                            <span class="rm-tag">Original Part</span>
                            <span class="rm-tag-desc">Primary manufacturer component ID.</span>
                        </li>
                        <li>
                            <span class="rm-icon-success">■</span>
                            <span class="rm-tag">Alternate Part</span>
                            <span class="rm-tag-desc">Proposed substitute component ID.</span>
                        </li>
                        <li>
                            <span class="rm-icon-success">■</span>
                            <span class="rm-tag">Remark</span>
                            <span class="rm-tag-desc">Condition trigger (e.g., "Alt", "Substitute").</span>
                        </li>
                        <li class="rm-divider">
                            <span class="rm-icon-info">□</span>
                            <span class="rm-tag">Optional Specs</span>
                            <span class="rm-tag-desc">Description, Manufacturer limits.</span>
                        </li>
                    </ul>
                </div>

                <button type="submit" class="rm-btn">
                    [ INITIALIZE COMPARISON SEQUENCE ]
                </button>

            </form>
        </div>

    </div>
</div>
