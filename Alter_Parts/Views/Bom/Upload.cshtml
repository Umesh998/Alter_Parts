<!-- Import Technical Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Space+Mono&display=swap" rel="stylesheet">

<style>
    /* ── RICHARD MILLE DARK THEME ── */
    .rm-theme-wrapper {
        background-color: #050505;
        color: #E0E0E0;
        font-family: 'Rajdhani', sans-serif;
        padding: 40px 0;
        min-height: 100vh;
    }

    .rm-container {
        max-width: 900px; /* Kept narrower for a focused upload form */
        margin: 0 auto;
        padding: 0 20px;
    }

    /* Architectural Headers */
    .rm-header {
        font-size: 2.2rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        border-bottom: 1px solid #333;
        padding-bottom: 15px;
        margin-bottom: 10px;
        color: #FFFFFF;
    }
    .rm-header span { color: #0088FF; /* Neon Blue Accent */ }
    
    .rm-subtitle {
        font-family: 'Space Mono', monospace;
        color: #888;
        font-size: 0.85rem;
        letter-spacing: 1px;
        margin-bottom: 30px;
    }

    /* Engineered Panels */
    .rm-panel {
        background-color: #0A0A0A;
        border: 1px solid #1A1A1A;
        border-top: 3px solid #0088FF;
        padding: 30px;
        margin-bottom: 30px;
    }

    /* Error Alert */
    .rm-alert-danger {
        background-color: rgba(255, 7, 58, 0.05);
        border: 1px solid #FF073A;
        border-left: 4px solid #FF073A;
        color: #FF073A;
        padding: 15px 20px;
        font-family: 'Space Mono', monospace;
        font-size: 0.85rem;
        margin-bottom: 25px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* Info Block */
    .rm-info-block {
        background-color: #111;
        border: 1px solid #222;
        padding: 20px;
        margin-top: 25px;
        margin-bottom: 30px;
    }
    .rm-info-header {
        color: #0088FF;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 15px;
        font-size: 0.9rem;
        border-bottom: 1px solid #222;
        padding-bottom: 10px;
    }
    .rm-info-list {
        list-style: none;
        padding: 0;
        margin: 0;
        font-size: 0.9rem;
    }
    .rm-info-list li {
        margin-bottom: 10px;
        display: flex;
        align-items: center;
    }
    .rm-icon-success { color: #39FF14; margin-right: 10px; font-size: 1.1rem; }
    .rm-icon-info { color: #0088FF; margin-right: 10px; font-size: 1.1rem; }

    /* Tags / Code elements */
    .rm-tag {
        font-family: 'Space Mono', monospace;
        background-color: rgba(255,255,255,0.05);
        border: 1px solid #333;
        color: #E0E0E0;
        padding: 2px 8px;
        font-size: 0.8rem;
        margin-right: 10px;
    }
    .rm-highlight { color: #39FF14; font-weight: bold; }

    /* Custom File Input Styling */
    .rm-input-label {
        display: block;
        color: #AAA;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        font-size: 0.85rem;
        margin-bottom: 10px;
    }
    .rm-file-input {
        display: block;
        width: 100%;
        padding: 12px 15px;
        font-family: 'Space Mono', monospace;
        font-size: 0.9rem;
        color: #FFF;
        background-color: #050505;
        border: 1px solid #333;
        outline: none;
        transition: border-color 0.3s;
    }
    .rm-file-input:focus, .rm-file-input:hover {
        border-color: #0088FF;
    }
    /* Styling the default 'Choose File' button inside the input */
    .rm-file-input::file-selector-button {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        background-color: #222;
        color: #FFF;
        border: 1px solid #444;
        padding: 6px 12px;
        margin-right: 15px;
        cursor: pointer;
        transition: background 0.2s;
    }
    .rm-file-input::file-selector-button:hover {
        background-color: #0088FF;
        border-color: #0088FF;
    }

    /* Tactical Button */
    .rm-btn {
        background-color: transparent;
        color: #FFF;
        border: 1px solid #0088FF;
        padding: 14px 28px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
        display: inline-block;
        width: 100%;
        text-align: center;
    }
    .rm-btn-primary { color: #0088FF; }
    .rm-btn-primary:hover { background-color: #0088FF; color: #000; text-decoration: none;}
</style>

<div class="rm-theme-wrapper">
    <div class="rm-container">
        
        <h2 class="rm-header">BOM <span>Upload Matrix</span></h2>
        <div class="rm-subtitle">
            SYSTEM INSTRUCTION: Upload target file. Matrix will only process rows flagged as <span class="rm-highlight">alternate</span> or <span class="rm-highlight">suggested</span>.
        </div>

        @if (ViewBag.Error != null)
        {
