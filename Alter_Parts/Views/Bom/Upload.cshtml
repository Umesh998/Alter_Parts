                            <span class="rm-icon-success">■</span>
                            <span class="rm-tag">Alternate Part</span> 
                            <span style="color: #888;">Proposed substitute component ID.</span>
                        </li>
                        <li>
                            <span class="rm-icon-success">■</span>
                            <span class="rm-tag">Remark</span> 
                            <span style="color: #888;">Condition trigger (e.g., "Alt", "Substitute").</span>
                        </li>
                        <li style="margin-top: 15px; border-top: 1px solid #222; padding-top: 15px;">
                            <span class="rm-icon-info">□</span>
                            <span class="rm-tag">Optional Specs</span> 
                            <span style="color: #555;">Description, Manufacturer limits.</span>
