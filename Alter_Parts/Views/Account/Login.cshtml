@model Alter_Parts.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    Layout = "~/Views/Account/_AccountLayout.cshtml";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<div class="ap-page">
    <div class="ap-card">
        <div class="ap-card-header">
            @* <div class="eyebrow">// auth.session</div> *@
            <h1>Sign In</h1>
        </div>

        <div class="ap-card-body">

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
            {
                <div class="alert alert-danger">
                    @Html.ValidationSummary(true)
                </div>
            }

            <form method="post" action="/Account/Login@(returnUrl != null ? "?returnUrl=" + Uri.EscapeDataString(returnUrl) : "")">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label" asp-for="Email">Email Address</label>
                    <input class="form-control" asp-for="Email" type="email"
                           placeholder="you@company.com" autocomplete="email" autofocus />
                    <span class="field-validation-error" asp-validation-for="Email"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Password">Password</label>
                    <input class="form-control" asp-for="Password" type="password"
                           placeholder="••••••••••••" autocomplete="current-password" />
                    <span class="field-validation-error" asp-validation-for="Password"></span>
                </div>

                <div class="form-check">
                    <input asp-for="RememberMe" type="checkbox" id="RememberMe" />
                    <label for="RememberMe">Keep me signed in for 8 hours</label>
                </div>

                <button type="submit" class="btn btn-primary">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" /><polyline points="10 17 15 12 10 7" /><line x1="15" y1="12" x2="3" y2="12" /></svg>
                    Authenticate
                </button>
            </form>
        </div>

        <div class="card-footer-link">
            No account? <a href="/Account/Register">Create one</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
