@model Alter_Parts.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Views/Account/_AccountLayout.cshtml";
}

<div class="ap-page" style="align-items:flex-start;padding-top:3rem">
    <div class="ap-card" style="max-width:560px;width:100%">
        <div class="ap-card-header">
            <div class="eyebrow">// user.profile</div>
            <h1>My Profile</h1>
        </div>

        <div class="ap-card-body">

            @if (TempData["Success"] != null)
            {
                <div class="tempdata-success">✓ &nbsp;@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="tempdata-error">✕ &nbsp;@TempData["Error"]</div>
            }

            <div class="profile-grid">
                <div class="profile-field">
                    <div class="pf-label">First Name</div>
                    <div class="pf-value">@(Model.FirstName ?? "—")</div>
                </div>
                <div class="profile-field">
                    <div class="pf-label">Last Name</div>
                    <div class="pf-value">@(Model.LastName ?? "—")</div>
                </div>
                <div class="profile-field" style="grid-column:1/-1">
                    <div class="pf-label">Email Address</div>
                    <div class="pf-value">@Model.Email</div>
                </div>
                <div class="profile-field" style="grid-column:1/-1">
                    <div class="pf-label">Assigned Roles</div>
                    <div class="roles-list">
                        @if (Model.Roles.Any())
                        {
                            foreach (var role in Model.Roles)
                            {
                                <span class="badge badge-role">@role</span>
                            }
                        }
                        else
                        {
                            <span style="color:var(--text-muted);font-size:.85rem">No roles assigned</span>
                        }
                    </div>
                </div>
            </div>

            <div class="divider">actions</div>

            <div style="display:flex;gap:.75rem;flex-wrap:wrap">
                <a href="/Account/ChangePassword" class="btn btn-outline" style="flex:1;min-width:160px">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                    Change Password
                </a>
                <a href="/" class="btn btn-outline" style="flex:1;min-width:160px">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" /></svg>
                    Dashboard
                </a>
                @if (User.IsInRole("Admin"))
                {
                    <a href="/Account/ManageUsers" class="btn btn-outline" style="flex:1;min-width:160px">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M23 21v-2a4 4 0 0 0-3-3.87" /><path d="M16 3.13a4 4 0 0 1 0 7.75" /></svg>
                        Manage Users
                    </a>
                }
            </div>
        </div>
    </div>
</div>
