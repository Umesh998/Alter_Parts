@model IList<Alter_Parts.ViewModels.UserListItemViewModel>
@{
    ViewData["Title"] = "Manage Users";
    Layout = "~/Views/Account/_AccountLayout.cshtml";
}

<div class="ap-page" style="align-items:flex-start;padding:2rem 1rem">
    <div class="ap-card wide" style="width:100%">

        <div class="ap-card-header" style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem">
            <div>
                <div class="eyebrow">// admin.users</div>
                <h1>Manage Users</h1>
            </div>
            <div style="display:flex;gap:.6rem;align-items:center;flex-wrap:wrap">
                <span style="font-family:var(--mono);font-size:.75rem;color:var(--text-muted)">
                    @Model.Count RECORD@(Model.Count != 1 ? "S" : "")
                </span>

                @* ── Dashboard button ── *@
                <a href="/Component/More_Fruits" class="btn btn-outline btn-sm">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                    </svg>
                    Dashboard
                </a>

                @* ── Add New User button ── *@
                <a href="/Account/CreateUser" class="btn btn-primary btn-sm" style="width:auto">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19" />
                        <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    Add User
                </a>
            </div>
        </div>

        <div class="ap-card-body" style="padding:0">

            @if (TempData["Success"] != null)
            {
                <div class="tempdata-success" style="margin:1.25rem 1.5rem 0">✓ &nbsp;@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="tempdata-error" style="margin:1.25rem 1.5rem 0">✕ &nbsp;@TempData["Error"]</div>
            }

            @if (!Model.Any())
            {
                <div style="padding:3rem;text-align:center;color:var(--text-muted);font-family:var(--mono);font-size:.85rem">
                    NO USERS FOUND
                </div>
            }
            else
            {
                <div style="overflow-x:auto">
                    <table class="ap-table">
                        <thead>
                            <tr>
                                <th>User</th>
                                <th>Email</th>
                                <th>Status</th>
                                <th>Assign Role</th>
                                <th>Revoke Role</th>
                                <th>Lock / Unlock</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td data-label="User">
                                        <span style="font-weight:600">@user.FirstName @user.LastName</span>
                                    </td>

                                    <td data-label="Email">
                                        <span style="font-family:var(--mono);font-size:.82rem;color:var(--text-muted)">
                                            @user.Email
                                        </span>
                                    </td>

                                    <td data-label="Status">
                                        @if (user.IsLockedOut)
                                        {
                                            <span class="badge badge-locked">Locked</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-active">Active</span>
                                        }
                                    </td>

                                    <td data-label="Assign Role">
                                        <form method="post" action="/Account/AssignRole" style="display:flex;gap:.4rem;align-items:center">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <select name="role" class="form-control"
                                                    style="padding:.3rem .6rem;font-size:.78rem;height:auto;width:auto;min-width:100px">
                                                <option value="User">User</option>
                                                <option value="Manager">Manager</option>
                                                <option value="Admin">Admin</option>
                                            </select>
                                            <button type="submit" class="btn btn-accent-sm">+</button>
                                        </form>
                                    </td>

                                    <td data-label="Revoke Role">
                                        <form method="post" action="/Account/RevokeRole" style="display:flex;gap:.4rem;align-items:center">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@user.Id" />
                                            <select name="role" class="form-control"
                                                    style="padding:.3rem .6rem;font-size:.78rem;height:auto;width:auto;min-width:100px">
                                                <option value="User">User</option>
                                                <option value="Manager">Manager</option>
                                                <option value="Admin">Admin</option>
                                            </select>
                                            <button type="submit" class="btn btn-danger">−</button>
                                        </form>
                                    </td>

                                    <td data-label="Lock / Unlock">
                                        @if (user.IsLockedOut)
                                        {
                                            <form method="post" action="/Account/UnlockUser">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit" class="btn btn-success">Unlock</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <form method="post" action="/Account/LockUser">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <button type="submit" class="btn btn-danger"
                                                        onclick="return confirm('Lock @user.Email?')">
                                                    Lock
                                                </button>
                                            </form>
                                        }
                                    </td>

                                    <td data-label="Actions">
                                        <div style="display:flex;gap:.4rem;flex-wrap:wrap">
                                            @* Edit button *@
                                            <a href="/Account/EditUser?userId=@user.Id" class="btn btn-accent-sm">
                                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                                </svg>
                                                Edit
                                            </a>

                                            @* Delete button — cannot delete yourself *@
                                            @if (user.Id != User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                            {
                                                <form method="post" action="/Account/DeleteUser">
                                                    @Html.AntiForgeryToken()
                                                    <input type="hidden" name="userId" value="@user.Id" />
                                                    <button type="submit" class="btn btn-danger"
                                                            onclick="return confirm('Permanently delete @user.Email? This cannot be undone.')">
                                                        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                                            <polyline points="3 6 5 6 21 6" />
                                                            <path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" />
                                                            <path d="M10 11v6M14 11v6" />
                                                        </svg>
                                                        Del
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <span style="font-family:var(--mono);font-size:.68rem;color:var(--text-muted);padding:.35rem 0">YOU</span>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>