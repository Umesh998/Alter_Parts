@model Alter_Parts.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
    Layout = "~/Views/Account/_AccountLayout.cshtml";
}

<div class="ap-page">
    <div class="ap-card">
        <div class="ap-card-header">
            <div class="eyebrow">// auth.credentials</div>
            <h1>Change Password</h1>
        </div>

        <div class="ap-card-body">

            @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ContainsKey(string.Empty))
            {
                <div class="alert alert-danger">
                    @Html.ValidationSummary(true)
                </div>
            }

            <form method="post" action="/Account/ChangePassword">
                @Html.AntiForgeryToken()

                <div class="form-group">
                    <label class="form-label" asp-for="CurrentPassword">Current Password</label>
                    <input class="form-control" asp-for="CurrentPassword" type="password"
                           placeholder="••••••••••••" autocomplete="current-password" autofocus />
                    <span class="field-validation-error" asp-validation-for="CurrentPassword"></span>
                </div>

                <div style="height:1px;background:var(--border);margin:1.25rem 0"></div>

                <div class="form-group">
                    <label class="form-label" asp-for="NewPassword">New Password</label>
                    <input class="form-control" asp-for="NewPassword" type="password"
                           placeholder="Min 12 chars" autocomplete="new-password" />
                    <span class="field-validation-error" asp-validation-for="NewPassword"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="ConfirmNewPassword">Confirm New Password</label>
                    <input class="form-control" asp-for="ConfirmNewPassword" type="password"
                           placeholder="••••••••••••" autocomplete="new-password" />
                    <span class="field-validation-error" asp-validation-for="ConfirmNewPassword"></span>
                </div>

                <div style="background:rgba(30,139,205,.06);border:1px solid rgba(30,139,205,.15);padding:.75rem 1rem;margin-bottom:1.25rem;font-size:.8rem;color:var(--text-muted);font-family:var(--mono);line-height:1.6">
                    PWD POLICY: 12+ chars &nbsp;·&nbsp; uppercase &nbsp;·&nbsp; lowercase &nbsp;·&nbsp; digit &nbsp;·&nbsp; symbol &nbsp;·&nbsp; 4 unique chars
                </div>

                <div style="display:flex;gap:.75rem">
                    <a href="/Account/Profile" class="btn btn-outline" style="flex:1">Cancel</a>
                    <button type="submit" class="btn btn-primary" style="flex:2">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" /><path d="M7 11V7a5 5 0 0 1 10 0v4" /></svg>
                        Update Password
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
