@* @model Alter_Parts.Models.CompareResult

@{
    ViewData["Title"] = "Comparison Result";

    var verdictBg = Model.RecommendedPart switch
    {
        "Alternate" => "success",
        "Original" => "warning",
        "Either" => "info",
        _ => "danger"
    };
}

<div class="container mt-4">
    <h3>⚖️ Comparison Result</h3>

    <!-- Part Numbers -->
    <div class="card mb-3 shadow-sm">
        <div class="card-body">
            <div class="row text-center">
                <div class="col-md-4">
                    <small class="text-muted">Original Part</small>
                    <div><span class="badge bg-primary fs-6">@Model.OriginalPart</span></div>
                    <small class="text-muted">Source: @Model.OriginalDetails?.Source</small>
                </div>
                <div class="col-md-4 d-flex align-items-center justify-content-center">
                    <span class="fs-4">⚖️</span>
                </div>
                <div class="col-md-4">
                    <small class="text-muted">Alternate Part</small>
                    <div><span class="badge bg-success fs-6">@Model.AlternatePart</span></div>
                    <small class="text-muted">Source: @Model.AlternateDetails?.Source</small>
                </div>
            </div>
            <hr />
            <div class="text-center">
                <small class="text-muted">Your Description:</small>
                <p class="fw-bold mb-0">@Model.UserDescription</p>
            </div>
        </div>
    </div>

    <!-- Final Verdict Banner -->
    <div class="alert alert-@verdictBg text-center mb-4">
        <h4 class="mb-1">@Model.Verdict</h4>
        <p class="mb-0">@Model.VerdictReason</p>
    </div>

    <!-- Match Score Cards -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card text-center border-primary
                @(Model.OriginalMatchScore >= Model.AlternateMatchScore ? "border-3" : "")">
                <div class="card-body">
                    <h6 class="text-muted">Original Part Description Match</h6>
                    <h2 class="text-primary">@Model.OriginalMatchScore%</h2>
                    <small>@Model.OriginalDetails?.FetchedDescription</small>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card text-center border-success
                @(Model.AlternateMatchScore >= Model.OriginalMatchScore ? "border-3" : "")">
                <div class="card-body">
                    <h6 class="text-muted">Alternate Part Description Match</h6>
                    <h2 class="text-success">@Model.AlternateMatchScore%</h2>
                    <small>@Model.AlternateDetails?.FetchedDescription</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Spec Comparison Table -->
    @if (Model.SpecComparisons.Any())
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-dark text-white">
                <h5 class="mb-0">📋 Spec Comparison</h5>
            </div>
            <div class="card-body table-responsive">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Specification</th>
                            <th class="text-center">
                                Original
                                <span class="badge bg-primary ms-1">@Model.OriginalPart</span>
                            </th>
                            <th class="text-center">
                                Alternate
                                <span class="badge bg-success ms-1">@Model.AlternatePart</span>
                            </th>
                            <th class="text-center">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var spec in Model.SpecComparisons)
                        {
                            var rowClass = spec.Status switch
                            {
                                "Match" => "table-success",
                                "Mismatch" => "table-danger",
                                "Only Original" => "table-warning",
                                _ => ""
                            };

                            var badge = spec.Status switch
                            {
                                "Match" => "<span class='badge bg-success'>✅ Match</span>",
                                "Mismatch" => "<span class='badge bg-danger'>❌ Mismatch</span>",
                                "Only Original" => "<span class='badge bg-warning text-dark'>Only Original</span>",
                                _ => "<span class='badge bg-secondary'>Only Alternate</span>"
                            };

                            <tr class="@rowClass">
                                <td>@spec.SpecName</td>
                                <td class="text-center">@spec.OriginalValue</td>
                                <td class="text-center">@spec.AlternateValue</td>
                                <td class="text-center">@Html.Raw(badge)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- Datasheet Links -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card p-3">
                <h6>🔗 Original Part Links</h6>
                @if (!string.IsNullOrEmpty(Model.OriginalDetails?.DatasheetUrl))
                {
                    <a href="@Model.OriginalDetails.DatasheetUrl" target="_blank"
                       class="btn btn-sm btn-outline-secondary me-1">📄 Datasheet</a>
                }
                @if (!string.IsNullOrEmpty(Model.OriginalDetails?.ProductUrl))
                {
                    <a href="@Model.OriginalDetails.ProductUrl" target="_blank"
                       class="btn btn-sm btn-outline-primary">🛒 @Model.OriginalDetails.Source</a>
                }
            </div>
        </div>
        <div class="col-md-6">
            <div class="card p-3">
                <h6>🔗 Alternate Part Links</h6>
                @if (!string.IsNullOrEmpty(Model.AlternateDetails?.DatasheetUrl))
                {
                    <a href="@Model.AlternateDetails.DatasheetUrl" target="_blank"
                       class="btn btn-sm btn-outline-secondary me-1">📄 Datasheet</a>
                }
                @if (!string.IsNullOrEmpty(Model.AlternateDetails?.ProductUrl))
                {
                    <a href="@Model.AlternateDetails.ProductUrl" target="_blank"
                       class="btn btn-sm btn-outline-success">🛒 @Model.AlternateDetails.Source</a>
                }
            </div>
        </div>
    </div>

    <!-- Action Buttons -->
    <div class="mt-2">
        <a asp-action="Compare" class="btn btn-primary">⚖️ Compare Another</a>
        <a asp-action="Index" class="btn btn-secondary ms-2">🔍 Verify a Part</a>
        <a asp-controller="Bom" asp-action="Upload" class="btn btn-secondary ms-2">📋 BOM Upload</a>
    </div>
</div> *@












@model Alter_Parts.Models.CompareResult

@{
    ViewData["Title"] = "Comparison Result";

    var verdictBorderColor = Model.RecommendedPart switch
    {
        "Alternate" => "var(--accent-green)",
        "Original"  => "#FF9900",
        "Either"    => "var(--accent-blue)",
        _           => "#FF073A"
    };

    var verdictTextColor = Model.RecommendedPart switch
    {
        "Alternate" => "var(--accent-green)",
        "Original"  => "#FF9900",
        "Either"    => "var(--accent-blue)",
        _           => "#FF073A"
    };
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Space+Mono&display=swap" rel="stylesheet">

<style>
    /* ── COMPARE RESULT PAGE STYLES ── */

    .rm-theme-wrapper {
        background-color: var(--bg-primary);
        color: var(--text-primary);
        font-family: 'Rajdhani', sans-serif;
        padding: 40px 0;
        min-height: 100vh;
    }

    .rm-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* ── HEADER ── */
    .rm-header {
        font-size: 2.2rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 15px;
        margin-bottom: 30px;
        color: var(--text-primary);
    }
    .rm-header span { color: var(--accent-green); }

    /* ── PANELS ── */
    .rm-panel {
        background-color: var(--bg-secondary);
        border: 1px solid var(--border-color);
        padding: 24px;
        margin-bottom: 24px;
    }

    .rm-panel-title {
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--text-muted);
        margin-bottom: 20px;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 10px;
    }

    /* ── PART COMPARISON HEADER ── */
    .rm-parts-grid {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 20px;
        align-items: center;
        text-align: center;
        margin-bottom: 20px;
    }

    .rm-part-box {
        background-color: var(--bg-card);
        border: 1px solid var(--border-color);
        padding: 16px;
    }

    .rm-part-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.72rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    .rm-part-number {
        font-family: 'Space Mono', monospace;
        font-size: 1rem;
        font-weight: bold;
        word-break: break-all;
    }

    .rm-part-source {
        font-family: 'Space Mono', monospace;
        font-size: 0.72rem;
        color: var(--text-muted);
        margin-top: 6px;
    }

    .rm-vs {
        font-size: 1.8rem;
        color: var(--text-muted);
        font-weight: 700;
    }

    .rm-user-desc {
        border-top: 1px solid var(--border-color);
        padding-top: 16px;
        text-align: center;
    }

    .rm-user-desc-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.72rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 6px;
    }

    .rm-user-desc-text {
        font-size: 1rem;
        font-weight: 600;
        color: var(--text-primary);
    }

    /* ── VERDICT BANNER ── */
    .rm-verdict {
        border: 1px solid;
        border-left: 4px solid;
        padding: 20px 24px;
        margin-bottom: 24px;
        text-align: center;
    }

    .rm-verdict-title {
        font-size: 1.3rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        margin-bottom: 6px;
    }

    .rm-verdict-reason {
        font-family: 'Space Mono', monospace;
        font-size: 0.82rem;
        color: var(--text-muted);
    }

    /* ── SCORE BOXES ── */
    .rm-score-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 24px;
    }

    .rm-score-box {
        background-color: var(--bg-secondary);
        border: 1px solid var(--border-color);
        padding: 20px;
        text-align: center;
    }

    .rm-score-box.winner {
        border-color: var(--accent-green);
        border-top: 3px solid var(--accent-green);
    }

    .rm-score-label {
        font-family: 'Space Mono', monospace;
        font-size: 0.72rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 10px;
    }

    .rm-score-value {
        font-family: 'Space Mono', monospace;
        font-size: 2.5rem;
        font-weight: 700;
        margin-bottom: 8px;
    }

    .rm-score-desc {
        font-size: 0.82rem;
        color: var(--text-muted);
        line-height: 1.5;
    }

    /* ── SPEC TABLE ── */
    .rm-table-wrapper {
        background-color: var(--bg-secondary);
        border: 1px solid var(--border-color);
        margin-bottom: 24px;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .rm-table-header {
        background-color: var(--bg-card);
        border-bottom: 1px solid var(--border-color);
        padding: 14px 20px;
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .rm-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 500px;
    }

    .rm-table th {
        background-color: var(--bg-card);
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 2px;
        padding: 12px 15px;
        font-size: 0.72rem;
        border-bottom: 1px solid var(--border-color);
        text-align: left;
        white-space: nowrap;
    }

    .rm-table td {
        padding: 12px 15px;
        border-bottom: 1px solid var(--border-subtle);
        vertical-align: middle;
        font-size: 0.9rem;
    }

    .rm-table tr:hover td { background-color: var(--bg-card); }

    .rm-row-match    { border-left: 3px solid var(--accent-green); }
    .rm-row-mismatch { border-left: 3px solid #FF073A; }
    .rm-row-only-orig{ border-left: 3px solid #FF9900; }
    .rm-row-only-alt { border-left: 3px solid var(--accent-blue); }

    /* ── SPEC BADGES ── */
    .rm-badge {
        padding: 4px 10px;
        font-size: 0.72rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-block;
        font-family: 'Space Mono', monospace;
    }
    .rm-badge-match    { background-color: rgba(57,255,20,0.1);  color: var(--accent-green); border: 1px solid var(--accent-green); }
    .rm-badge-mismatch { background-color: rgba(255,7,58,0.1);   color: #FF073A; border: 1px solid #FF073A; }
    .rm-badge-warn     { background-color: rgba(255,153,0,0.1);  color: #FF9900; border: 1px solid #FF9900; }
    .rm-badge-info     { background-color: rgba(0,136,255,0.1);  color: var(--accent-blue); border: 1px solid var(--accent-blue); }

    /* ── LINKS PANEL ── */
    .rm-links-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        margin-bottom: 24px;
    }

    .rm-link-box {
        background-color: var(--bg-secondary);
        border: 1px solid var(--border-color);
        padding: 18px;
    }

    .rm-link-title {
        font-family: 'Space Mono', monospace;
        font-size: 0.78rem;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 12px;
    }

    .rm-link-btn {
        display: inline-block;
        background-color: transparent;
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        padding: 7px 14px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.82rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none;
        transition: all 0.2s;
        margin-right: 8px;
        margin-bottom: 6px;
    }
    .rm-link-btn:hover { background-color: var(--text-primary); color: var(--bg-primary); border-color: var(--text-primary); text-decoration: none; }

    /* ── ACTION BUTTONS ── */
    .rm-controls {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        margin-bottom: 40px;
    }

    .rm-btn {
        background-color: transparent;
        color: var(--text-primary);
        border: 1px solid var(--border-color);
        padding: 12px 24px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
        display: inline-block;
    }
    .rm-btn:hover { background-color: var(--text-primary); color: var(--bg-primary); text-decoration: none; }
    .rm-btn-primary { border-color: var(--accent-blue); color: var(--accent-blue); }
    .rm-btn-primary:hover { background-color: var(--accent-blue); color: #000; }
    .rm-btn-success { border-color: var(--accent-green); color: var(--accent-green); }
    .rm-btn-success:hover { background-color: var(--accent-green); color: #000; }

    /* ── RESPONSIVE: TABLET ── */
    @@media (max-width: 768px) {
        .rm-theme-wrapper { padding: 20px 0; }
        .rm-header { font-size: 1.5rem; letter-spacing: 1.5px; }
        .rm-score-value { font-size: 2rem; }
        .rm-btn { padding: 10px 16px; font-size: 0.82rem; letter-spacing: 1px; }
    }

    /* ── RESPONSIVE: MOBILE ── */
    @@media (max-width: 576px) {
        .rm-container { padding: 0 12px; }
        .rm-header { font-size: 1.2rem; letter-spacing: 1px; }

        /* Parts grid stacks vertically */
        .rm-parts-grid {
            grid-template-columns: 1fr;
            gap: 12px;
        }
        .rm-vs { font-size: 1.2rem; }

        /* Score boxes stack */
        .rm-score-grid {
            grid-template-columns: 1fr;
            gap: 12px;
        }
        .rm-score-value { font-size: 1.8rem; }

        /* Links stack */
        .rm-links-grid {
            grid-template-columns: 1fr;
            gap: 12px;
        }

        /* Controls stack */
        .rm-controls { flex-direction: column; }
        .rm-btn { width: 100%; text-align: center; }

        .rm-panel { padding: 16px 12px; }
        .rm-verdict { padding: 16px 12px; }
        .rm-verdict-title { font-size: 1rem; letter-spacing: 1px; }
        .rm-table th, .rm-table td { padding: 10px 8px; font-size: 0.8rem; }
    }
</style>

<div class="rm-theme-wrapper">
    <div class="rm-container">

        <h2 class="rm-header">Differential <span>Analysis</span> Result</h2>

        <!-- Part Numbers Panel -->
        <div class="rm-panel">
            <div class="rm-panel-title">Component Nodes</div>
            <div class="rm-parts-grid">
                <div class="rm-part-box">
                    <div class="rm-part-label">Original Part</div>
                    <div class="rm-part-number" style="color: var(--accent-blue);">@Model.OriginalPart</div>
                    <div class="rm-part-source">SOURCE: @Model.OriginalDetails?.Source</div>
                </div>
                <div class="rm-vs">⚖️</div>
                <div class="rm-part-box">
                    <div class="rm-part-label">Alternate Part</div>
                    <div class="rm-part-number" style="color: var(--accent-green);">@Model.AlternatePart</div>
                    <div class="rm-part-source">SOURCE: @Model.AlternateDetails?.Source</div>
                </div>
            </div>
            <div class="rm-user-desc">
                <div class="rm-user-desc-label">Baseline Parameters</div>
                <div class="rm-user-desc-text">@Model.UserDescription</div>
            </div>
        </div>

        <!-- Verdict Banner -->
        <div class="rm-verdict" style="border-color: @verdictBorderColor; color: @verdictTextColor;">
            <div class="rm-verdict-title">@Model.Verdict</div>
            <div class="rm-verdict-reason">@Model.VerdictReason</div>
        </div>

        <!-- Match Scores -->
        <div class="rm-score-grid">
            <div class="rm-score-box @(Model.OriginalMatchScore >= Model.AlternateMatchScore ? "winner" : "")">
                <div class="rm-score-label">Original Part Match</div>
                <div class="rm-score-value" style="color: var(--accent-blue);">@Model.OriginalMatchScore%</div>
                <div class="rm-score-desc">@Model.OriginalDetails?.FetchedDescription</div>
            </div>
            <div class="rm-score-box @(Model.AlternateMatchScore >= Model.OriginalMatchScore ? "winner" : "")">
                <div class="rm-score-label">Alternate Part Match</div>
                <div class="rm-score-value" style="color: var(--accent-green);">@Model.AlternateMatchScore%</div>
                <div class="rm-score-desc">@Model.AlternateDetails?.FetchedDescription</div>
            </div>
        </div>

        <!-- Spec Comparison Table -->
        @if (Model.SpecComparisons.Any())
        {
            <div class="rm-table-wrapper">
                <div class="rm-table-header">📋 Spec Comparison Matrix</div>
                <table class="rm-table">
                    <thead>
                        <tr>
                            <th>Specification</th>
                            <th>Original — @Model.OriginalPart</th>
                            <th>Alternate — @Model.AlternatePart</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var spec in Model.SpecComparisons)
                        {
                            var rowClass = spec.Status switch
                            {
                                "Match"         => "rm-row-match",
                                "Mismatch"      => "rm-row-mismatch",
                                "Only Original" => "rm-row-only-orig",
                                _               => "rm-row-only-alt"
                            };
                            var badgeClass = spec.Status switch
                            {
                                "Match"         => "rm-badge-match",
                                "Mismatch"      => "rm-badge-mismatch",
                                "Only Original" => "rm-badge-warn",
                                _               => "rm-badge-info"
                            };
                            var badgeText = spec.Status switch
                            {
                                "Match"         => "✅ Match",
                                "Mismatch"      => "❌ Mismatch",
                                "Only Original" => "Only Original",
                                _               => "Only Alternate"
                            };
                            <tr class="@rowClass">
                                <td>@spec.SpecName</td>
                                <td>@spec.OriginalValue</td>
                                <td>@spec.AlternateValue</td>
                                <td><span class="rm-badge @badgeClass">@badgeText</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- Datasheet Links -->
        <div class="rm-links-grid">
            <div class="rm-link-box">
                <div class="rm-link-title">🔗 Original Part Links</div>
                @if (!string.IsNullOrEmpty(Model.OriginalDetails?.DatasheetUrl))
                {
                    <a href="@Model.OriginalDetails.DatasheetUrl" target="_blank" class="rm-link-btn">📄 Datasheet</a>
                }
                @if (!string.IsNullOrEmpty(Model.OriginalDetails?.ProductUrl))
                {
                    <a href="@Model.OriginalDetails.ProductUrl" target="_blank" class="rm-link-btn">🛒 @Model.OriginalDetails.Source</a>
                }
            </div>
            <div class="rm-link-box">
                <div class="rm-link-title">🔗 Alternate Part Links</div>
                @if (!string.IsNullOrEmpty(Model.AlternateDetails?.DatasheetUrl))
                {
                    <a href="@Model.AlternateDetails.DatasheetUrl" target="_blank" class="rm-link-btn">📄 Datasheet</a>
                }
                @if (!string.IsNullOrEmpty(Model.AlternateDetails?.ProductUrl))
                {
                    <a href="@Model.AlternateDetails.ProductUrl" target="_blank" class="rm-link-btn">🛒 @Model.AlternateDetails.Source</a>
                }
            </div>
        </div>

        <!-- Action Buttons -->
        <div class="rm-controls">
            <a asp-action="Compare" class="rm-btn rm-btn-success">[⚖️] COMPARE ANOTHER</a>
            <a asp-action="Index" class="rm-btn rm-btn-primary">[🔍] VERIFY A PART</a>
            <a asp-controller="Bom" asp-action="Upload" class="rm-btn">[📋] BOM UPLOAD</a>
        </div>

    </div>
</div>
