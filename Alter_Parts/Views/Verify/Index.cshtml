@model Alter_Parts.Models.VerifyRequest

@{
    ViewData["Title"] = "Verify Part Number";
}

<!-- Import Technical Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Space+Mono&display=swap" rel="stylesheet">

<style>
    /* ── RICHARD MILLE DARK THEME ── */
    .rm-theme-wrapper {
        background-color: #050505;
        color: #E0E0E0;
        font-family: 'Rajdhani', sans-serif;
        padding: 40px 0;
        min-height: 100vh;
    }

    .rm-container {
        max-width: 800px; /* Narrower for a focused terminal */
        margin: 0 auto;
        padding: 0 20px;
    }

    /* Architectural Headers */
    .rm-header {
        font-size: 2.2rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        border-bottom: 1px solid #333;
        padding-bottom: 15px;
        margin-bottom: 10px;
        color: #FFFFFF;
    }
    .rm-header span { color: #0088FF; /* Neon Blue Accent */ }
    
    .rm-subtitle {
        font-family: 'Space Mono', monospace;
        color: #888;
        font-size: 0.85rem;
        letter-spacing: 1px;
        margin-bottom: 30px;
        text-transform: uppercase;
    }

    /* Engineered Panels */
    .rm-panel {
        background-color: #0A0A0A;
        border: 1px solid #1A1A1A;
        border-top: 3px solid #0088FF;
        padding: 40px 35px;
        margin-bottom: 30px;
    }

    /* Form Inputs */
    .rm-input-label {
        display: block;
        color: #AAA;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-size: 0.85rem;
        margin-bottom: 10px;
    }

    .rm-text-input {
        display: block;
        width: 100%;
        padding: 14px 15px;
        font-family: 'Space Mono', monospace;
        font-size: 1rem;
        color: #FFF;
        background-color: #050505;
        border: 1px solid #333;
        outline: none;
        transition: all 0.3s ease;
    }

    .rm-text-input:focus {
        border-color: #0088FF;
        box-shadow: 0 0 10px rgba(0, 136, 255, 0.1);
    }

    .rm-text-input::placeholder {
        color: #444;
    }

    textarea.rm-text-input {
        resize: vertical;
        min-height: 100px;
    }

    /* Validation Errors */
    .rm-validation-text {
        color: #FF073A;
        font-size: 0.8rem;
        font-family: 'Space Mono', monospace;
        margin-top: 8px;
        display: block;
        text-transform: uppercase;
    }

    /* Tactical Buttons */
    .rm-btn {
        background-color: transparent;
        padding: 16px 28px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
        display: block;
        width: 100%;
        text-align: center;
        border: 1px solid transparent;
    }

    .rm-btn-primary { 
        color: #0088FF; 
        border-color: #0088FF; 
    }
    .rm-btn-primary:hover { 
        background-color: #0088FF; 
        color: #000; 
    }
</style>

<div class="rm-theme-wrapper">
    <div class="rm-container">
        
        <h2 class="rm-header">Verify <span>Component</span></h2>
        <div class="rm-subtitle">
            System Instruction: Input target node ID and expected parameters to cross-reference against primary distributors.
        </div>

        <div class="rm-panel">
            <form asp-action="Index" method="post">
                
                <div style="margin-bottom: 30px;">
                    <label asp-for="PartNumber" class="rm-input-label">Target Part Number</label>
                    <input asp-for="PartNumber" class="rm-text-input" placeholder="e.g. LM358N, CC0402MRX5R6BB106" autocomplete="off" />
                    <span asp-validation-for="PartNumber" class="rm-validation-text"></span>
                </div>

                <div style="margin-bottom: 40px;">
                    <label asp-for="Description" class="rm-input-label">Expected Parameters / Description</label>
                    <textarea asp-for="Description" class="rm-text-input" rows="4" placeholder="e.g. Op-Amp, Dual, 1MHz, 3-32V, DIP-8"></textarea>
                    <span asp-validation-for="Description" class="rm-validation-text"></span>
                </div>

                <button type="submit" class="rm-btn rm-btn-primary">
                    [ INITIALIZE VERIFICATION PROTOCOL ]
                </button>

            </form>
        </div>

    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}