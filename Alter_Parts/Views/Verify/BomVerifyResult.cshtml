    .rm-badge {
        padding: 4px 10px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        display: inline-block;
        font-family: 'Space Mono', monospace;
        margin-bottom: 4px;
        margin-right: 4px;
    }
    .rm-badge-primary { background-color: rgba(0,136,255,0.1); color: var(--accent-blue); border: 1px solid var(--accent-blue); }
    .rm-badge-mouser  { background-color: rgba(57,255,20,0.1);  color: var(--accent-green); border: 1px solid var(--accent-green); }
    .rm-badge-lcsc    { background-color: rgba(255,7,58,0.1);   color: #FF073A; border: 1px solid #FF073A; }
    .rm-badge-dark    { background-color: var(--bg-card); color: var(--text-muted); border: 1px solid var(--border-color); }

    .rm-progress-bg { height: 4px; background: var(--border-color); margin-top: 8px; overflow: hidden; }
    .rm-progress-fill { height: 100%; }

    /* Mobile cards — hidden on desktop */
    .rm-mobile-cards { display: none; }

    .rm-card {
        background-color: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-left: 3px solid var(--accent-blue);
        margin-bottom: 12px;
        padding: 14px;
    }
    .rm-card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 6px;
        gap: 8px;
    }
    .rm-card-part {
        font-family: 'Space Mono', monospace;
        font-size: 0.85rem;
        font-weight: bold;
        color: var(--text-primary);
        word-break: break-all;
    }
    .rm-card-id {
        font-family: 'Space Mono', monospace;
        font-size: 0.75rem;
        color: var(--footer-text);
        white-space: nowrap;
    }
    .rm-card-manufacturer {
        font-size: 0.72rem;
        color: var(--text-muted);
        text-transform: uppercase;
        margin-bottom: 8px;
    }
    .rm-card-desc {
        font-size: 0.82rem;
        color: var(--text-muted);
        margin-bottom: 10px;
        border-top: 1px solid var(--border-subtle);
        padding-top: 8px;
    }
    .rm-card-verdict {
        font-weight: 600;
        font-size: 0.85rem;
        margin-bottom: 6px;
    }
    .rm-card-sources {
        display: flex;
        flex-direction: column;
        gap: 4px;
        margin-top: 8px;
        border-top: 1px solid var(--border-subtle);
        padding-top: 8px;
    }
    .rm-card-source-item {
        font-size: 0.75rem;
        font-family: 'Space Mono', monospace;
        color: var(--text-muted);
    }

    /* Buttons */
    .rm-controls {
        display: flex;
        flex-wrap: wrap;
        gap: 15px;
        margin-bottom: 40px;
    }
    .rm-btn {
        background-color: transparent;
        color: var(--text-primary);
        border: 1px solid var(--border-color);
        padding: 12px 24px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.9rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .rm-btn:hover { background-color: var(--text-primary); color: var(--bg-primary); text-decoration: none; }
    .rm-btn-success { border-color: var(--accent-green); color: var(--accent-green); }
    .rm-btn-success:hover { background-color: var(--accent-green); color: #000; }
    .rm-btn-primary { border-color: var(--accent-blue); color: var(--accent-blue); }
    .rm-btn-primary:hover { background-color: var(--accent-blue); color: #000; }

    @@media (max-width: 768px) { {
        .rm-theme-wrapper { padding: 20px 0; }
        .rm-header { font-size: 1.5rem; letter-spacing: 1.5px; }
        .rm-stat-value { font-size: 1.8rem; }
        .rm-stat-label { font-size: 0.7rem; letter-spacing: 1px; }
        .rm-btn { padding: 10px 16px; font-size: 0.8rem; letter-spacing: 1px; }
    }

    @@media (max-width: 768px) {) {
        .rm-container { padding: 0 12px; }
        .rm-header { font-size: 1.2rem; letter-spacing: 1px; }
        .rm-stat-value { font-size: 1.5rem; }
        .rm-stat-label { font-size: 0.65rem; letter-spacing: 0.5px; }
        .rm-table-wrapper { display: none; }
        .rm-mobile-cards { display: block; }
        .rm-controls { flex-direction: column; }
        .rm-btn { width: 100%; text-align: center; justify-content: center; }
    }
</style>

<div class="rm-theme-wrapper">
    <div class="rm-container">

        <h2 class="rm-header">AI <span>Verification</span> Matrix</h2>
        <div class="rm-filename">SOURCE_FILE // @Model.FileName</div>

        <div class="row mb-4">
            <div class="col-6 col-md-3 mb-3 mb-md-0">
                <div class="rm-stat-box border-primary">
                    <div class="rm-stat-value" style="color: var(--accent-blue);">@Model.TotalRows</div>
                    <div class="rm-stat-label">Nodes Processed</div>
                </div>
            </div>
            <div class="col-6 col-md-3 mb-3 mb-md-0">
                <div class="rm-stat-box border-success">
                    <div class="rm-stat-value" style="color: var(--accent-green);">@Model.MatchedCount</div>
                    <div class="rm-stat-label">Verified Exact</div>
                </div>
            </div>
            <div class="col-6 col-md-3 mb-3 mb-md-0">
                <div class="rm-stat-box border-danger">
                    <div class="rm-stat-value" style="color: #FF073A;">@Model.NotMatchedCount</div>
                    <div class="rm-stat-label">Anomalies Detected</div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="rm-stat-box border-warning">
                    <div class="rm-stat-value" style="color: #FF9900;">@Model.ManualCheckCount</div>
                    <div class="rm-stat-label">Manual Override</div>
                </div>
            </div>
        </div>

        <!-- Desktop Table -->
        <div class="rm-table-wrapper">
            <table class="rm-table">
                <thead>
                    <tr>
                        <th style="width: 4%;">ID</th>
                        <th style="width: 18%;">Component Matrix</th>
                        <th style="width: 20%;">Target Input</th>
                        <th style="width: 22%;">System Resolution</th>
                        <th style="width: 12%;">DigiKey</th>
                        <th style="width: 12%;">Mouser</th>
                        <th style="width: 12%;">LCSC</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in Model.Rows)
                    {
                        <tr>
                            <td class="rm-mono rm-row-number">@row.RowNumber.ToString("D3")</td>
                            <td>
                                <div class="rm-mono rm-part-number">@row.PartNumber</div>
                                <div class="rm-manufacturer">@(string.IsNullOrEmpty(row.Manufacturer) ? "UNKNOWN ORG" : row.Manufacturer)</div>
                            </td>
                            <td class="rm-user-desc">@row.UserDescription</td>
                            <td>
                                @if (!string.IsNullOrEmpty(row.BestSource))
                                {
                                    var sourceClass = row.BestSource == "DigiKey" ? "rm-badge-primary" :
                                                      row.BestSource == "Mouser"  ? "rm-badge-mouser"  :
                                                      row.BestSource == "LCSC"    ? "rm-badge-lcsc"    : "rm-badge-dark";
                                    <span class="rm-badge @sourceClass">@row.BestSource</span>
                                }
                                <div style="font-weight:600;font-size:0.9rem;margin-top:4px;">
                                    <span style="color:@(row.MatchVerdict?.StartsWith("✅")==true?"var(--accent-green)":row.MatchVerdict?.StartsWith("❌")==true?"#FF073A":"#FF9900");">
                                        @row.MatchVerdict?.Replace("✅","")?.Replace("❌","")?.Replace("⚠️","")
                                    </span>
                                </div>
                                @if (row.MatchScore > 0)
                                {
                                    var barColor = row.MatchScore >= 80 ? "var(--accent-green)" : row.MatchScore >= 50 ? "#FF9900" : "#FF073A";
                                    <div class="rm-progress-bg"><div class="rm-progress-fill" style="width:@(row.MatchScore)%;background:@barColor;"></div></div>
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(row.DigiKeyVerdict))
                                {
                                    <div style="color:@(row.DigiKeyVerdict.StartsWith("✅")?"var(--accent-green)":row.DigiKeyVerdict.StartsWith("❌")?"#FF073A":"#FF9900");font-weight:600;font-size:0.85rem;">@row.DigiKeyVerdict.Replace("✅","").Replace("❌","").Replace("⚠️","")</div>
                                    @if (row.DigiKeyScore > 0) { <div class="rm-score-label">SCORE: @row.DigiKeyScore</div> }
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(row.MouserVerdict))
                                {
                                    <div style="color:@(row.MouserVerdict.StartsWith("✅")?"var(--accent-green)":row.MouserVerdict.StartsWith("❌")?"#FF073A":"#FF9900");font-weight:600;font-size:0.85rem;">@row.MouserVerdict.Replace("✅","").Replace("❌","").Replace("⚠️","")</div>
                                    @if (row.MouserScore > 0) { <div class="rm-score-label">SCORE: @row.MouserScore</div> }
                                }
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(row.LCSCVerdict))
                                {
                                    <div style="color:@(row.LCSCVerdict.StartsWith("✅")?"var(--accent-green)":row.LCSCVerdict.StartsWith("❌")?"#FF073A":"#FF9900");font-weight:600;font-size:0.85rem;">@row.LCSCVerdict.Replace("✅","").Replace("❌","").Replace("⚠️","")</div>
                                    @if (row.LCSCScore > 0) { <div class="rm-score-label">SCORE: @row.LCSCScore</div> }
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Mobile Cards -->
        <div class="rm-mobile-cards">
            @foreach (var row in Model.Rows)
            {
                <div class="rm-card">
                    <div class="rm-card-header">
                        <div>
                            <div class="rm-card-part">@row.PartNumber</div>
                            <div class="rm-card-manufacturer">@(string.IsNullOrEmpty(row.Manufacturer) ? "UNKNOWN ORG" : row.Manufacturer)</div>
                        </div>
                        <div class="rm-card-id">#@row.RowNumber.ToString("D3")</div>
                    </div>
                    <div class="rm-card-desc">@row.UserDescription</div>
                    <div class="rm-card-verdict">
                        @if (!string.IsNullOrEmpty(row.BestSource))
                        {
                            var sc = row.BestSource == "DigiKey" ? "rm-badge-primary" : row.BestSource == "Mouser" ? "rm-badge-mouser" : row.BestSource == "LCSC" ? "rm-badge-lcsc" : "rm-badge-dark";
                            <span class="rm-badge @sc">@row.BestSource</span>
                        }
                        <span style="color:@(row.MatchVerdict?.StartsWith("✅")==true?"var(--accent-green)":row.MatchVerdict?.StartsWith("❌")==true?"#FF073A":"#FF9900");">
                            @row.MatchVerdict?.Replace("✅","")?.Replace("❌","")?.Replace("⚠️","")
                        </span>
                    </div>
                    @if (row.MatchScore > 0)
                    {
                        var bc = row.MatchScore >= 80 ? "var(--accent-green)" : row.MatchScore >= 50 ? "#FF9900" : "#FF073A";
                        <div class="rm-progress-bg"><div class="rm-progress-fill" style="width:@(row.MatchScore)%;background:@bc;"></div></div>
                    }
                    <div class="rm-card-sources">
                        @if (!string.IsNullOrEmpty(row.DigiKeyVerdict))
                        {
                            <div class="rm-card-source-item">DIGIKEY: <span style="color:@(row.DigiKeyVerdict.StartsWith("✅")?"var(--accent-green)":row.DigiKeyVerdict.StartsWith("❌")?"#FF073A":"#FF9900");">@row.DigiKeyVerdict.Replace("✅","").Replace("❌","").Replace("⚠️","")</span>@if(row.DigiKeyScore>0){<span style="color:var(--text-muted);"> (@row.DigiKeyScore)</span>}</div>
                        }
                        @if (!string.IsNullOrEmpty(row.MouserVerdict))
                        {
                            <div class="rm-card-source-item">MOUSER: <span style="color:@(row.MouserVerdict.StartsWith("✅")?"var(--accent-green)":row.MouserVerdict.StartsWith("❌")?"#FF073A":"#FF9900");">@row.MouserVerdict.Replace("✅","").Replace("❌","").Replace("⚠️","")</span>@if(row.MouserScore>0){<span style="color:var(--text-muted);"> (@row.MouserScore)</span>}</div>
                        }
                        @if (!string.IsNullOrEmpty(row.LCSCVerdict))
                        {
                            <div class="rm-card-source-item">LCSC: <span style="color:@(row.LCSCVerdict.StartsWith("✅")?"var(--accent-green)":row.LCSCVerdict.StartsWith("❌")?"#FF073A":"#FF9900");">@row.LCSCVerdict.Replace("✅","").Replace("❌","").Replace("⚠️","")</span>@if(row.LCSCScore>0){<span style="color:var(--text-muted);"> (@row.LCSCScore)</span>}</div>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Control Panel -->
        <form asp-action="ExportVerifyResults" method="post" class="rm-controls">
            <input type="hidden" name="resultsJson" value="@JsonSerializer.Serialize(Model.Rows)" />
            <button type="submit" class="rm-btn rm-btn-success">[+] EXPORT PAYLOAD</button>
            <a asp-action="BomVerify" class="rm-btn rm-btn-primary">[>] NEW MATRIX</a>
            <a asp-controller="Component" asp-action="More_Fruits" class="rm-btn">[«] RETURN TO CORE</a>
        </form>

    </div>
</div>
