                                    {
                                        <div style="color: @(row.MouserVerdict.StartsWith("✅") ? "var(--accent-green)" : row.MouserVerdict.StartsWith("❌") ? "#FF073A" : "#FFB000"); font-weight: 600; font-size: 0.85rem;">
