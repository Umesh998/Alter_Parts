<div class="aurora-theme-wrapper">
    <div class="aurora-container">

        <h1 class="glass-header">AI Verification Matrix</h1>
        <div class="glass-filename">SOURCE_FILE // @Model.FileName</div>

        <!-- Stat Cards -->
        <div class="stat-grid">
