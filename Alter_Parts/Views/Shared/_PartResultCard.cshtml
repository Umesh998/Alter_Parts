@model Alter_Parts.Models.PartDetails

@{
    var scoreStr = Model.Specs
        .GetValueOrDefault("Match Score", "0")
        .Replace("%", "");
    double.TryParse(scoreStr, out var matchScore);

    var matchColor =
        matchScore >= 80 ? "success" :
        matchScore >= 50 ? "warning" : "secondary";

    var stockNum = long.TryParse(Model.Stock, out var s)
        ? s : 0;
    var stockColor =
        stockNum > 1000 ? "success" :
        stockNum > 0 ? "warning" : "danger";

    var unitPrice = Model.Specs
        .GetValueOrDefault("Unit Price", "N/A");

    var sourceBadge =
     Model.Source == "DigiKey" ? "bg-primary" :
     Model.Source == "Mouser" ? "bg-success" :
     Model.Source == "LCSC" ? "bg-danger" :
                                 "bg-secondary";

    var sourcePN = Model.Source == "DigiKey"
        ? Model.Specs.GetValueOrDefault("DigiKey PN", "")
        : Model.Specs.GetValueOrDefault("Mouser PN", "");
}

<style>
    /* Force text to black regardless of Bootstrap/Theme settings */
    .dark-text { color: #000 !important; }
    .dark-label { color: #222 !important; font-weight: 600; }
</style>

<div class="col-md-6 mb-3">
    <div class="card h-100 shadow-sm border-@matchColor">
        <div class="card-header d-flex justify-content-between align-items-center">
            <div>
                <span class="badge @sourceBadge me-1">
                    @Model.Source
                </span>
                <span class="badge bg-dark me-1">
                    @Model.Mpn
                </span>
                @if (!string.IsNullOrEmpty(sourcePN))
                {
                    <span class="badge bg-secondary small">
                        @sourcePN
                    </span>
                }
            </div>
            <span class="badge bg-@matchColor">
                @matchScore% match
            </span>
        </div>

        <div class="card-body">
            <p class="fw-bold mb-2 small dark-text">@Model.Description</p>

            <div class="row g-1 small mb-2">
                @if (!string.IsNullOrEmpty(Model.Manufacturer))
                {
                    <div class="col-6">
                        <span class="dark-label">Manufacturer:</span>
                        <strong class="dark-text">@Model.Manufacturer</strong>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Category))
                {
                    <div class="col-6">
                        <span class="dark-label">Category:</span>
                        <span class="dark-text">@Model.Category</span>
                    </div>
                }
                @if (Model.Specs.TryGetValue("Package / Case", out var pkg) || Model.Specs.TryGetValue("Case/Package", out pkg))
                {
                    <div class="col-6">
                        <span class="dark-label">Package:</span>
                        <strong class="dark-text">@pkg</strong>
                    </div>
                }
            </div>

            <div class="d-flex gap-3 align-items-center mb-2">
                <div>
                    <span class="dark-label small">Price:</span>
                    <strong class="text-success">@unitPrice</strong>
                </div>
                <div>
                    <span class="dark-label small">Stock:</span>
                    <span class="badge bg-@stockColor">
                        @(stockNum > 0
                            ? $"{stockNum:N0} units"
                            : Model.Stock)
                    </span>
                </div>
            </div>

            <div class="progress mb-2" style="height:6px">
                <div class="progress-bar bg-@matchColor"
                     style="width:@matchScore%"></div>
            </div>

            @{
                var displaySpecs = Model.Specs
                    .Where(s =>
                        s.Key != "Unit Price" &&
                        s.Key != "Match Score" &&
                        s.Key != "DigiKey PN" &&
                        s.Key != "Mouser PN")
                    .Take(4).ToList();
            }
            @if (displaySpecs.Any())
            {
                <div class="d-flex flex-wrap gap-1 mt-1">
                    @foreach (var spec in displaySpecs)
                    {
                        <span class="badge bg-light border small dark-text">
                            @spec.Key: @spec.Value
                        </span>
                    }
                </div>
            }
        </div>

        <div class="card-footer bg-transparent">
            <div class="d-flex gap-2 flex-wrap">
                @if (!string.IsNullOrEmpty(Model.ProductUrl))
                {
                    <a href="@Model.ProductUrl" target="_blank"
                       class="btn btn-sm btn-outline-@(Model.Source == "DigiKey" ? "primary" : "success")">
                        🛒 @Model.Source
                    </a>
                }
                @if (!string.IsNullOrEmpty(Model.DatasheetUrl))
                {
                    <a href="@Model.DatasheetUrl" target="_blank"
                       class="btn btn-sm btn-outline-secondary">
                        📄 Datasheet
                    </a>
                }
                @if (!string.IsNullOrEmpty(Model.Mpn))
                {
                    <a asp-controller="Verify"
                       asp-action="Index"
                       asp-route-partNumber="@Model.Mpn"
                       class="btn btn-sm btn-outline-dark">
                        🔍 Verify
                    </a>
                }
            </div>
        </div>
    </div>
</div>










