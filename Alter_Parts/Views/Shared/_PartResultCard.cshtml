<style>
    .rm-part-card {
        background-color: #0A0A0A;
        border: 1px solid #222;
        padding: 20px;
        height: 100%;
        display: flex;
        flex-direction: column;
        transition: border-color 0.3s ease, transform 0.2s ease;
    }
    .rm-part-card:hover { border-color: #555; transform: translateY(-3px); }

    .rm-card-btn {
        background-color: transparent;
        padding: 6px 12px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        text-decoration: none;
        transition: all 0.2s ease;
        display: inline-block;
        border: 1px solid transparent;
    }
    .rm-card-btn:hover { color: #000 !important; text-decoration: none; }
</style>

<div class="col-lg-6 mb-4">
    <div class="rm-part-card" style="border-top: 3px solid @matchHex;">
        
        <!-- Header -->
        <div style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #151515; padding-bottom: 15px; margin-bottom: 15px;">
            <div>
                <span style="background-color: @sourceBgHex; color: @sourceHex; border: 1px solid @sourceHex; padding: 4px 8px; font-family: 'Space Mono', monospace; font-size: 0.75rem; font-weight: bold; margin-right: 5px;">
                    @Model.Source.ToUpper()
                </span>
                <span style="background-color: #111; color: #FFF; border: 1px solid #333; padding: 4px 8px; font-family: 'Space Mono', monospace; font-size: 0.75rem; font-weight: bold; margin-right: 5px;">
                    @Model.Mpn
                </span>
                @if (!string.IsNullOrEmpty(sourcePN))
                {
                    <span style="background-color: #050505; color: #888; border: 1px solid #222; padding: 4px 8px; font-family: 'Space Mono', monospace; font-size: 0.7rem;">
                        @sourcePN
                    </span>
                }
            </div>
            <span style="background-color: @matchBgHex; color: @matchHex; border: 1px solid @matchHex; padding: 4px 8px; font-family: 'Space Mono', monospace; font-size: 0.75rem; font-weight: bold;">
                @matchScore% MATCH
            </span>
        </div>

        <!-- Body -->
        <div style="flex-grow: 1;">
            <p style="font-family: 'Space Mono', monospace; font-size: 0.95rem; font-weight: bold; color: #FFF; margin-bottom: 15px;">
                @Model.Description
            </p>

            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px; margin-bottom: 15px; font-family: 'Rajdhani', sans-serif;">
                @if (!string.IsNullOrEmpty(Model.Manufacturer))
                {
                    <div style="display: flex; flex-direction: column;">
                        <span style="color: #666; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px;">Manufacturer</span>
                        <span style="color: #E0E0E0; font-size: 0.9rem; font-weight: 600;">@Model.Manufacturer</span>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.Category))
                {
                    <div style="display: flex; flex-direction: column;">
                        <span style="color: #666; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px;">Category</span>
                        <span style="color: #E0E0E0; font-size: 0.85rem; font-weight: 600;">@Model.Category</span>
                    </div>
                }
                @if (Model.Specs.TryGetValue("Package / Case", out var pkg) || Model.Specs.TryGetValue("Case/Package", out pkg))
                {
                    <div style="display: flex; flex-direction: column;">
                        <span style="color: #666; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px;">Package</span>
                        <span style="color: #E0E0E0; font-size: 0.9rem; font-weight: 600;">@pkg</span>
                    </div>
                }
            </div>

            <!-- Price + Stock -->
            <div style="display: flex; gap: 20px; align-items: center; margin-bottom: 15px;">
                <div style="display: flex; flex-direction: column;">
                    <span style="color: #666; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px;">Unit Price</span>
                    <span style="color: #39FF14; font-family: 'Space Mono', monospace; font-size: 0.95rem; font-weight: bold;">@unitPrice</span>
                </div>
                <div style="display: flex; flex-direction: column;">
                    <span style="color: #666; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px;">Inventory Stock</span>
                    <span style="color: @stockHex; font-family: 'Space Mono', monospace; font-size: 0.95rem; font-weight: bold;">
                        @(stockNum > 0 ? $"{stockNum:N0} UNITS" : Model.Stock.ToUpper())
                    </span>
                </div>
            </div>

            <!-- Match Luminous Bar -->
            <div style="height: 4px; background-color: #111; width: 100%; margin-bottom: 15px; border-radius: 2px; overflow: hidden;">
                <div style="height: 100%; width: @matchScore%; background-color: @matchHex; box-shadow: 0 0 8px @matchHex;"></div>
            </div>

            <!-- Specs Data Tags -->
            @{
                var displaySpecs = Model.Specs
                    .Where(s => s.Key != "Unit Price" && s.Key != "Match Score" && s.Key != "DigiKey PN" && s.Key != "Mouser PN")
                    .Take(4).ToList();
            }
            @if (displaySpecs.Any())
            {
                <div style="display: flex; flex-wrap: wrap; gap: 6px; margin-top: 10px;">
                    @foreach (var spec in displaySpecs)
                    {
                        <span style="background-color: rgba(255,255,255,0.05); color: #AAA; border: 1px solid #333; padding: 3px 6px; font-family: 'Space Mono', monospace; font-size: 0.7rem; text-transform: uppercase;">
                            @spec.Key: <span style="color: #E0E0E0;">@spec.Value</span>
                        </span>
                    }
                </div>
            }
        </div>

        <!-- Footer Terminal Links -->
        <div style="display: flex; gap: 10px; margin-top: 20px; flex-wrap: wrap;">
            @if (!string.IsNullOrEmpty(Model.ProductUrl))
            {
                <a href="@Model.ProductUrl" target="_blank" class="rm-card-btn" style="border-color: @sourceHex; color: @sourceHex;" onmouseover="this.style.backgroundColor='@sourceHex'" onmouseout="this.style.backgroundColor='transparent'">
                    [🛒] @Model.Source
                </a>
            }
            @if (!string.IsNullOrEmpty(Model.DatasheetUrl))
            {
                <a href="@Model.DatasheetUrl" target="_blank" class="rm-card-btn" style="border-color: #444; color: #888;" onmouseover="this.style.backgroundColor='#FFF'; this.style.borderColor='#FFF';" onmouseout="this.style.backgroundColor='transparent'; this.style.borderColor='#444';">
                    [📄] DATASHEET
                </a>
            }
            @if (!string.IsNullOrEmpty(Model.Mpn))
            {
                <a asp-controller="Verify" asp-action="Index" asp-route-partNumber="@Model.Mpn" class="rm-card-btn" style="border-color: #FFF; color: #FFF;" onmouseover="this.style.backgroundColor='#FFF'; this.style.color='#000';" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#FFF';">
                    [🔍] VERIFY
                </a>
            }
        </div>
        
    </div>
</div> *@








