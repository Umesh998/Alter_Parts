                                    <td class="rm-desc-cell">@group.RequestedDescription</td>
                                    <td colspan="6" class="rm-no-results">— NO RESULTS FOUND —</td>
                                </tr>
                            }
                            else
                            {
                                for (int i = 0; i < group.Results.Count; i++)
                                {
                                    var part = group.Results[i];
                                    bool isLast = i == group.Results.Count - 1;
                                    <tr class="@(isLast ? "rm-group-separator" : "")">
                                        @if (i == 0)
                                        {
                                            <td class="rm-desc-cell" rowspan="@rowCount">@group.RequestedDescription</td>
                                        }
                                        <td><span class="rm-source-@(part.Source?.ToLower() ?? "unknown")">@(part.Source?.ToUpper() ?? "UNKNOWN")</span></td>
                                        <td class="rm-mono">@part.Mpn</td>
                                        <td>@part.Manufacturer</td>
                                        <td class="rm-mono">@(string.IsNullOrWhiteSpace(part.Price) ? part.Specs.GetValueOrDefault("Unit Price", "N/A") : part.Price)</td>
                                        <td class="rm-mono">@part.Stock</td>
                                        <td>
                                            @if (!string.IsNullOrWhiteSpace(part.ProductUrl))
                                            { <a href="@part.ProductUrl" target="_blank" class="rm-link">View →</a> }
                                            else
                                            { <span class="rm-no-results">—</span> }
                                        </td>
                                    </tr>
                                }
                            }
                        }
                    </tbody>
                </table>
            </div>

            <!-- ── MOBILE CARDS ── -->
            <div class="rm-mobile-cards">
                @foreach (var group in groups)
                {
                    if (group.Results.Count == 0)
                    {
                        <div class="rm-no-results-card">
                            <div style="margin-bottom: 4px; color: var(--text-muted);">@group.RequestedDescription</div>
                            — NO RESULTS FOUND —
                        </div>
                    }
                    else
                    {
                        <div class="rm-card">
                            <div class="rm-card-desc">@group.RequestedDescription</div>
                            @foreach (var part in group.Results)
                            {
                                <div class="rm-card-part">
                                    <div class="rm-card-part-header">
                                        <div class="rm-card-mpn">@part.Mpn</div>
                                        <span class="rm-source-@(part.Source?.ToLower() ?? "unknown")">@(part.Source?.ToUpper() ?? "UNKNOWN")</span>
                                    </div>
                                    <div style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 6px;">@part.Manufacturer</div>
                                    <div class="rm-card-row">
                                        <span>PRICE: <span>@(string.IsNullOrWhiteSpace(part.Price) ? part.Specs.GetValueOrDefault("Unit Price", "N/A") : part.Price)</span></span>
                                        <span>STOCK: <span>@part.Stock</span></span>
                                    </div>
                                    @if (!string.IsNullOrWhiteSpace(part.ProductUrl))
                                    {
                                        <div style="margin-top: 8px;">
                                            <a href="@part.ProductUrl" target="_blank" class="rm-link">View Product →</a>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        }

    </div>
</div>

<script>
    document.getElementById('sourcingForm').addEventListener('submit', function () {
        document.getElementById('submitBtn').disabled = true;
        document.getElementById('submitBtn').innerText = 'PROCESSING...';
        document.getElementById('loadingMsg').style.display = 'block';
    });
</script>
