@{
    ViewData["Title"] = "Bulk Component Sourcing";
    List<Alter_Parts.Models.BulkResultGroup> groups = ViewBag.Groups as List<Alter_Parts.Models.BulkResultGroup> ?? new();
    bool hasResults = groups.Any();
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Space+Mono&display=swap" rel="stylesheet">

<style>
    /* ── BULK SOURCING PAGE STYLES ── */
    /* All colors use CSS variables defined in _Layout.cshtml */

    .rm-theme-wrapper {
        background-color: var(--bg-primary);
        color: var(--text-primary);
        font-family: 'Rajdhani', sans-serif;
        padding: 40px 0;
        min-height: 100vh;
    }

    .rm-container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* ── HEADER ── */
    .rm-header {
        font-size: 2.2rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 15px;
        margin-bottom: 30px;
        color: var(--text-primary);
    }
    .rm-header span { color: var(--accent-green); }

    /* ── BACK LINK ── */
    .rm-back {
        display: inline-block;
        margin-bottom: 25px;
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        color: var(--text-muted);
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 1px;
        transition: color 0.2s;
    }
    .rm-back:hover { color: var(--text-primary); text-decoration: none; }

    /* ── UPLOAD BOX ── */
    .rm-upload-box {
        background-color: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-top: 3px solid var(--accent-green);
        padding: 30px;
        margin-bottom: 30px;
    }

    .rm-label {
        display: block;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--text-muted);
        margin-bottom: 10px;
        font-family: 'Space Mono', monospace;
    }

    .rm-file-input {
        width: 100%;
        padding: 12px;
        background-color: var(--bg-primary);
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        font-family: 'Space Mono', monospace;
        font-size: 0.85rem;
        margin-bottom: 20px;
        cursor: pointer;
        box-sizing: border-box;
        transition: border-color 0.3s;
    }
    .rm-file-input:hover { border-color: var(--accent-green); }

    .rm-file-input::file-selector-button {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        background-color: var(--bg-card);
        color: var(--text-primary);
        border: 1px solid var(--border-color);
        padding: 6px 12px;
        margin-right: 12px;
        cursor: pointer;
        transition: background 0.2s;
    }
    .rm-file-input::file-selector-button:hover {
        background-color: var(--accent-green);
        border-color: var(--accent-green);
        color: #000;
    }

    .rm-hint {
        font-family: 'Space Mono', monospace;
        font-size: 0.75rem;
        color: var(--footer-text);
        margin-top: -15px;
        margin-bottom: 20px;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    /* ── BUTTONS ── */
    .rm-btn {
        background-color: transparent;
        padding: 12px 30px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        cursor: pointer;
        transition: all 0.2s ease;
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        text-decoration: none;
        display: inline-block;
        white-space: nowrap;
    }
    .rm-btn-success { border-color: var(--accent-green); color: var(--accent-green); }
    .rm-btn-success:hover { background-color: var(--accent-green); color: #000; text-decoration: none; }
    .rm-btn-primary { border-color: var(--accent-blue); color: var(--accent-blue); }
    .rm-btn-primary:hover { background-color: var(--accent-blue); color: #000; text-decoration: none; }
    .rm-btn:disabled { border-color: var(--border-color); color: var(--text-muted); cursor: not-allowed; }

    /* ── LOADING ── */
    .rm-loading {
        display: none;
        font-family: 'Space Mono', monospace;
        font-size: 0.85rem;
        color: var(--accent-green);
        letter-spacing: 2px;
        text-transform: uppercase;
        margin-top: 15px;
    }

    /* ── ALERTS ── */
    .rm-alert-error {
        background-color: rgba(255,7,58,0.05);
        border: 1px solid #FF073A;
        border-left: 4px solid #FF073A;
        color: #FF073A;
        padding: 15px 20px;
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        margin-bottom: 25px;
        word-break: break-word;
    }
    .rm-alert-success {
        background-color: rgba(57,255,20,0.05);
        border: 1px solid var(--accent-green);
        border-left: 4px solid var(--accent-green);
        color: var(--accent-green);
        padding: 15px 20px;
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
        margin-bottom: 25px;
    }

    /* ── RESULTS HEADER ── */
    .rm-results-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
        flex-wrap: wrap;
        gap: 12px;
    }
    .rm-results-title {
        font-size: 1.4rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--text-primary);
    }
    .rm-results-title span { color: var(--accent-blue); }

    /* ── DESKTOP TABLE ── */
    .rm-table-wrapper {
        background-color: var(--bg-secondary);
        border: 1px solid var(--border-color);
        overflow-x: auto;
        margin-bottom: 30px;
        -webkit-overflow-scrolling: touch;
    }
    .rm-table {
        width: 100%;
        border-collapse: collapse;
        min-width: 750px;
    }
    .rm-table th {
        background-color: var(--bg-card);
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 2px;
        padding: 12px 15px;
        font-size: 0.75rem;
        border-bottom: 1px solid var(--border-color);
        text-align: left;
        white-space: nowrap;
    }
    .rm-table td {
        padding: 12px 15px;
        border-bottom: 1px solid var(--border-subtle);
        vertical-align: middle;
        font-size: 0.9rem;
    }
    .rm-table tr:hover td { background-color: var(--bg-card); }

    /* ── TYPOGRAPHY ── */
    .rm-mono { font-family: 'Space Mono', monospace; font-size: 0.85rem; color: var(--text-primary); }
    .rm-desc-cell {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 1rem;
        color: var(--text-primary);
        border-right: 2px solid var(--border-color);
    }
    .rm-source-mouser  { color: #FF9900; font-family: 'Space Mono', monospace; font-size: 0.8rem; font-weight: 700; }
    .rm-source-digikey { color: var(--accent-green); font-family: 'Space Mono', monospace; font-size: 0.8rem; font-weight: 700; }
    .rm-source-lcsc    { color: var(--accent-blue); font-family: 'Space Mono', monospace; font-size: 0.8rem; font-weight: 700; }
    .rm-group-separator td { border-bottom: 2px solid var(--border-color) !important; }
    .rm-link { color: var(--accent-blue); font-family: 'Space Mono', monospace; font-size: 0.8rem; text-decoration: underline; }
    .rm-link:hover { color: var(--text-primary); }
    .rm-no-results { color: var(--footer-text); font-family: 'Space Mono', monospace; font-size: 0.8rem; }

    /* ── MOBILE CARDS ── */
    .rm-mobile-cards { display: none; }

    .rm-card {
        background-color: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-left: 3px solid var(--accent-green);
        margin-bottom: 12px;
        padding: 14px;
    }
    .rm-card-desc {
        font-family: 'Rajdhani', sans-serif;
        font-weight: 700;
        font-size: 1rem;
        color: var(--text-primary);
        margin-bottom: 10px;
        border-bottom: 1px solid var(--border-subtle);
        padding-bottom: 8px;
    }
    .rm-card-part {
        background-color: var(--bg-card);
        border: 1px solid var(--border-subtle);
        padding: 10px;
        margin-bottom: 8px;
    }
    .rm-card-part-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 6px;
        flex-wrap: wrap;
        gap: 4px;
    }
    .rm-card-mpn {
        font-family: 'Space Mono', monospace;
        font-size: 0.82rem;
        color: var(--text-primary);
        font-weight: bold;
        word-break: break-all;
    }
    .rm-card-row {
        display: flex;
        justify-content: space-between;
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 4px;
        flex-wrap: wrap;
        gap: 4px;
    }
    .rm-card-row span {
        font-family: 'Space Mono', monospace;
        color: var(--text-primary);
    }
    .rm-no-results-card {
        background-color: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-left: 3px solid var(--footer-text);
        margin-bottom: 12px;
        padding: 14px;
        color: var(--footer-text);
        font-family: 'Space Mono', monospace;
        font-size: 0.8rem;
    }

    /* ── RESPONSIVE: TABLET ── */
    @@media (max-width: 768px) {
        .rm-theme-wrapper { padding: 20px 0; }
        .rm-header { font-size: 1.5rem; letter-spacing: 1.5px; }
        .rm-upload-box { padding: 20px 15px; }
        .rm-btn { padding: 10px 20px; font-size: 0.85rem; letter-spacing: 1px; }
        .rm-results-title { font-size: 1.1rem; }
    }

    /* ── RESPONSIVE: MOBILE ── */
    @@media (max-width: 576px) {
        .rm-container { padding: 0 12px; }
        .rm-header { font-size: 1.2rem; letter-spacing: 1px; }
        .rm-upload-box { padding: 14px 12px; }
        .rm-hint { font-size: 0.68rem; letter-spacing: 0.5px; }
        .rm-file-input { font-size: 0.78rem; padding: 10px; }
        .rm-file-input::file-selector-button { font-size: 0.72rem; padding: 5px 8px; margin-right: 8px; }
        .rm-btn { width: 100%; text-align: center; padding: 12px 16px; font-size: 0.82rem; letter-spacing: 0.5px; }
        .rm-results-header { flex-direction: column; align-items: flex-start; }
        .rm-results-title { font-size: 1rem; }

        /* Hide table, show cards */
        .rm-table-wrapper { display: none; }
        .rm-mobile-cards { display: block; }
    }
</style>

