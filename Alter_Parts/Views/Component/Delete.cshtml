@model Alter_Parts.Models.Alter

@{
    ViewData["Title"] = "Delete Confirmation";
}

<!-- Import Technical Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Space+Mono&display=swap" rel="stylesheet">

<style>
    /* ── RICHARD MILLE DARK THEME ── */
    .rm-theme-wrapper {
        background-color: #050505;
        color: #E0E0E0;
        font-family: 'Rajdhani', sans-serif;
        padding: 40px 0;
        min-height: 100vh;
    }

    .rm-container {
        max-width: 800px; /* Narrower for focus */
        margin: 0 auto;
        padding: 0 20px;
    }

    /* Architectural Headers */
    .rm-header {
        font-size: 2.2rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        border-bottom: 1px solid #333;
        padding-bottom: 15px;
        margin-bottom: 10px;
        color: #FFFFFF;
    }
    .rm-header span { color: #FF073A; /* Laser Red Accent for Deletion */ }
    
    .rm-subtitle {
        font-family: 'Space Mono', monospace;
        color: #FF073A;
        font-size: 0.85rem;
        letter-spacing: 1px;
        margin-bottom: 30px;
        text-transform: uppercase;
        background-color: rgba(255, 7, 58, 0.05);
        padding: 10px 15px;
        border-left: 3px solid #FF073A;
    }

    /* Engineered Panels (Danger Variant) */
    .rm-panel-danger {
        background-color: #0A0A0A;
        border: 1px solid #1A1A1A;
        border-top: 3px solid #FF073A;
        padding: 35px 30px;
        margin-bottom: 30px;
    }

    /* Data Display Blocks */
    .rm-data-group {
        margin-bottom: 25px;
        padding-bottom: 20px;
        border-bottom: 1px solid #151515;
    }
    .rm-data-group:last-of-type {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .rm-data-label {
        color: #AAA;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }

    .rm-data-value {
        font-family: 'Space Mono', monospace;
        font-size: 1.25rem;
        color: #FFF;
        background-color: #111;
        padding: 12px 15px;
        border: 1px solid #222;
        letter-spacing: 1px;
    }

    /* Tactical Buttons */
    .rm-btn-group {
        display: flex;
        gap: 15px;
        margin-top: 35px;
    }
    
    .rm-btn {
        background-color: transparent;
        padding: 14px 28px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
        text-align: center;
        flex: 1; /* Makes buttons equal width */
    }

    .rm-btn-danger { 
        color: #FF073A; 
        border: 1px solid #FF073A; 
    }
    .rm-btn-danger:hover { 
        background-color: #FF073A; 
        color: #000; 
    }

    .rm-btn-secondary { 
        color: #888; 
        border: 1px solid #444; 
    }
    .rm-btn-secondary:hover { 
        background-color: #FFF; 
        color: #000; 
        border-color: #FFF;
    }
</style>

<div class="rm-theme-wrapper">
    <div class="rm-container">
        
        <h2 class="rm-header">Delete <span>Record</span></h2>
        
        <div class="rm-subtitle">
            [!] WARNING: You are about to permanently terminate this matrix pairing.
        </div>

        <div class="rm-panel-danger">
            
            <div class="rm-data-group">
                <div class="rm-data-label">Original Component ID</div>
                <div class="rm-data-value">@Model.Original_Part_Number</div>
            </div>

            <div class="rm-data-group">
                <div class="rm-data-label">Alternate Component ID</div>
                <div class="rm-data-value" style="color: #0088FF;">@Model.Alter_Part_Number</div>
            </div>

            <form asp-action="DeleteConfirmed" method="post" class="rm-btn-group">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Part_Id" name="id" />
                
                <button type="submit" class="rm-btn rm-btn-danger">
                    [x] CONFIRM TERMINATION
                </button>
                
                <a asp-action="More_Fruits" class="rm-btn rm-btn-secondary">
                    [<] ABORT PROTOCOL
                </a>
            </form>

        </div>

    </div>
</div>