    .rm-panel-danger {
        background-color: #0A0A0A;
        border: 1px solid #1A1A1A;
        border-top: 3px solid #FF073A;
        padding: 35px 30px;
        margin-bottom: 30px;
    }

    /* Data Display Blocks */
    .rm-data-group {
        margin-bottom: 25px;
        padding-bottom: 20px;
        border-bottom: 1px solid #151515;
    }
    .rm-data-group:last-of-type {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .rm-data-label {
        color: #AAA;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }

    .rm-data-value {
        font-family: 'Space Mono', monospace;
        font-size: 1.25rem;
        color: #FFF;
