    .rm-btn-group {
        display: flex;
        gap: 15px;
        margin-top: 35px;
    }
    
    .rm-btn {
        background-color: transparent;
        padding: 14px 28px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
        text-align: center;
        flex: 1; /* Makes buttons equal width */
    }

    .rm-btn-danger { 
        color: #FF073A; 
        border: 1px solid #FF073A; 
    }
    .rm-btn-danger:hover { 
        background-color: #FF073A; 
        color: #000; 
    }

    .rm-btn-secondary { 
        color: #888; 
        border: 1px solid #444; 
    }
    .rm-btn-secondary:hover { 
        background-color: #FFF; 
        color: #000; 
        border-color: #FFF;
    }
</style>

<div class="rm-theme-wrapper">
    <div class="rm-container">
        
        <h2 class="rm-header">Delete <span>Record</span></h2>
        
