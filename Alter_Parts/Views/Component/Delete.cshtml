@model Alter_Parts.Models.Alter

@{
    ViewData["Title"] = "Delete Confirmation";
}

<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=Space+Mono&display=swap" rel="stylesheet">

<style>
    /* ── DELETE PAGE STYLES ── */
    /* All colors use CSS variables defined in _Layout.cshtml */

    .rm-theme-wrapper {
        background-color: var(--bg-primary);
        color: var(--text-primary);
        font-family: 'Rajdhani', sans-serif;
        padding: 40px 0;
        min-height: 100vh;
    }

    .rm-container {
        max-width: 800px;
        margin: 0 auto;
        padding: 0 20px;
    }

    /* ── HEADER ── */
    .rm-header {
        font-size: 2.2rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 3px;
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 15px;
        margin-bottom: 10px;
        color: var(--text-primary);
    }
    .rm-header span { color: #FF073A; }

    /* ── WARNING SUBTITLE ── */
    .rm-subtitle {
        font-family: 'Space Mono', monospace;
        color: #FF073A;
        font-size: 0.85rem;
        letter-spacing: 1px;
        margin-bottom: 30px;
        text-transform: uppercase;
        background-color: rgba(255, 7, 58, 0.05);
        padding: 10px 15px;
        border-left: 3px solid #FF073A;
        line-height: 1.6;
    }

    /* ── DANGER PANEL ── */
    .rm-panel-danger {
        background-color: var(--bg-secondary);
        border: 1px solid var(--border-color);
        border-top: 3px solid #FF073A;
        padding: 35px 30px;
        margin-bottom: 30px;
    }

    /* ── DATA DISPLAY ── */
    .rm-data-group {
        margin-bottom: 25px;
        padding-bottom: 20px;
        border-bottom: 1px solid var(--border-subtle);
    }
    .rm-data-group:last-of-type {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .rm-data-label {
        color: var(--text-muted);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        font-size: 0.85rem;
        margin-bottom: 8px;
    }

    .rm-data-value {
        font-family: 'Space Mono', monospace;
        font-size: 1.25rem;
        color: var(--text-primary);
        background-color: var(--bg-card);
        padding: 12px 15px;
        border: 1px solid var(--border-color);
        letter-spacing: 1px;
        word-break: break-all;
    }

    /* ── BUTTONS ── */
    .rm-btn-group {
        display: flex;
        gap: 15px;
        margin-top: 35px;
        flex-wrap: wrap;
    }

    .rm-btn {
        background-color: transparent;
        padding: 14px 28px;
        font-family: 'Rajdhani', sans-serif;
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
        text-align: center;
        flex: 1;
        border: 1px solid transparent;
        box-sizing: border-box;
    }

    .rm-btn-danger {
        color: #FF073A;
        border-color: #FF073A;
    }
    .rm-btn-danger:hover {
        background-color: #FF073A;
        color: #000;
        text-decoration: none;
    }

    .rm-btn-secondary {
        color: var(--text-muted);
        border-color: var(--border-color);
    }
    .rm-btn-secondary:hover {
        background-color: var(--text-primary);
        color: var(--bg-primary);
        border-color: var(--text-primary);
        text-decoration: none;
    }

    /* ── RESPONSIVE: TABLET ── */
    @@media (max-width: 768px) {
        .rm-theme-wrapper { padding: 20px 0; }
        .rm-header { font-size: 1.5rem; letter-spacing: 1.5px; }
        .rm-panel-danger { padding: 24px 20px; }
        .rm-btn { font-size: 0.9rem; padding: 12px 20px; letter-spacing: 1.5px; }
        .rm-data-value { font-size: 1rem; }
    }

    /* ── RESPONSIVE: MOBILE ── */
    @@media (max-width: 576px) {
        .rm-container { padding: 0 12px; }
        .rm-header { font-size: 1.2rem; letter-spacing: 1px; }
        .rm-subtitle { font-size: 0.75rem; letter-spacing: 0.5px; }
        .rm-panel-danger { padding: 16px 12px; }
        .rm-data-label { font-size: 0.78rem; letter-spacing: 1px; }
        .rm-data-value { font-size: 0.88rem; padding: 10px 12px; }

        .rm-btn-group {
            flex-direction: column;
            gap: 10px;
            margin-top: 24px;
        }
        .rm-btn {
            flex: none;
            width: 100%;
            font-size: 0.85rem;
            padding: 13px 16px;
            letter-spacing: 1px;
        }
    }
</style>

<div class="rm-theme-wrapper">
    <div class="rm-container">

        <h2 class="rm-header">Delete <span>Record</span></h2>

        <div class="rm-subtitle">
            [!] WARNING: You are about to permanently terminate this matrix pairing.
        </div>

        <div class="rm-panel-danger">

            <div class="rm-data-group">
                <div class="rm-data-label">Original Component ID</div>
                <div class="rm-data-value">@Model.Original_Part_Number</div>
            </div>

            <div class="rm-data-group">
                <div class="rm-data-label">Alternate Component ID</div>
                <div class="rm-data-value" style="color: var(--accent-blue);">@Model.Alter_Part_Number</div>
            </div>

            <form asp-action="DeleteConfirmed" method="post" class="rm-btn-group">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Part_Id" name="id" />

                <button type="submit" class="rm-btn rm-btn-danger">
                    [x] CONFIRM TERMINATION
                </button>

                <a asp-action="More_Fruits" class="rm-btn rm-btn-secondary">
                    [&lt;] ABORT PROTOCOL
                </a>
            </form>

        </div>

    </div>
</div>
