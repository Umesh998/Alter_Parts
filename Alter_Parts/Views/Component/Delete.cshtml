        padding-bottom: 15px;
        margin-bottom: 10px;
        color: #FFFFFF;
    }
    .rm-header span { color: #FF073A; /* Laser Red Accent for Deletion */ }
    
    .rm-subtitle {
        font-family: 'Space Mono', monospace;
        color: #FF073A;
        font-size: 0.85rem;
        letter-spacing: 1px;
        margin-bottom: 30px;
        text-transform: uppercase;
        background-color: rgba(255, 7, 58, 0.05);
        padding: 10px 15px;
        border-left: 3px solid #FF073A;
    }

