<style>
    /* ── RICHARD MILLE DARK THEME ── */
    .rm-theme-wrapper {
        background-color: #050505;
        color: #E0E0E0;
        font-family: 'Rajdhani', sans-serif;
        padding: 40px 0;
        min-height: 100vh;
    }

    .rm-container {
        max-width: 800px; /* Narrower for focus */
        margin: 0 auto;
        padding: 0 20px;
